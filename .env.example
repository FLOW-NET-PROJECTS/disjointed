# Railway single-service runtime
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# Frontend build base path. Use / for a normal Railway root deploy.
BASE_PATH=/

# Supabase Postgres connection string for the app database.
# Replace the placeholder below with your real Supabase URI.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres?sslmode=require

# Optional web push notifications.
# Leave blank if you are not enabling push notifications yet.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
